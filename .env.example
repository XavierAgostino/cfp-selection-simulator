# =============================================================================
# CFP Selection Simulator - Environment Variables Template
# =============================================================================
#
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
#

# CollegeFootballData.com API Key
# Get your free API key at: https://collegefootballdata.com/key
# Used by Python CLI (sroom run) and the web app's server-side live runs.
CFBD_API_KEY=your_api_key_here

# Optional: Database Configuration (for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/cfp_simulator

# Optional: Development Settings
# DEBUG=True
# LOG_LEVEL=INFO

# Selection Room web app — server-backed run generation
# Requires persistent Node + Python + writable data/output/
# SELECTION_ROOM_ENABLE_RUN_JOBS=1
# SELECTION_ROOM_LIVE_RUN_THROTTLE_MINUTES=0
# SELECTION_ROOM_REPO_DIR=/path/to/cfp-selection-simulator
# SELECTION_ROOM_DATA_DIR=/path/to/cfp-selection-simulator/data/output/api

# Public demo (Vercel) — see web/.env.example
# NEXT_PUBLIC_SELECTION_ROOM_DEMO_MODE=1
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# DuckDB run store — fail export on store write errors (default: 1)
# Set to 0 to continue JSON export if DuckDB write fails (local debugging only)
# SELECTION_ROOM_STORE_REQUIRED=1

# Hosted runs (H2+) — server/worker only; not required for local OSS or public demo
# SELECTION_ROOM_RUNTIME=hosted
# SELECTION_ROOM_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=artifacts
# SELECTION_ROOM_ARTIFACT_STORE=filesystem|supabase
# SELECTION_ROOM_HOSTED_DAILY_JOB_CAP=10
# SELECTION_ROOM_HOSTED_MAX_CONCURRENT=1
# SELECTION_ROOM_BETA_ACCESS_CODE=
# SELECTION_ROOM_BETA_RUN_CODES=code1,code2
# TRIGGER_SECRET_KEY=tr_dev_...
# TRIGGER_PROJECT_REF=proj_...
# SELECTION_ROOM_HOSTED_EXECUTOR=trigger
# SELECTION_ROOM_PYTHON=python3
# SELECTION_ROOM_WORKER_DATA_OUTPUT=/tmp/sroom-worker-output
