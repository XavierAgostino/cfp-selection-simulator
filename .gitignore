# =============================================================================
# Selection Room - .gitignore
# =============================================================================

# Environment Variables
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.Python
.venv/
venv/
ENV/
env/
.python-version

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE & Editors
.vscode/
.idea/
.ipython/
.local/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Package managers (local store at repo root)
.pnpm-store/

# Web demo bundle (generated at Vercel build; do not commit)
web/.demo-data/

# Logs (repo-root only; do not match web/app/api/.../logs/)
/logs/
*.log
*.log.*

# Data & Cache
data/cache/*
!data/cache/team_assets.sample.json
data/raw/
data/processed/*
!data/processed/sample/
data/processed/sample/*
!data/processed/sample/sample_games.csv
!data/processed/sample/sample_champions.csv
*.pkl
*.pickle
*.h5
*.hdf5
*.parquet

# Output Files (keep output directory structure but ignore contents)
data/output/**/*
!data/output/**/.gitkeep

# Legacy output paths (pre-v2.0)
data/output/rankings/*.csv
data/output/rankings/*.json
data/output/fields/*
data/output/brackets/*
data/output/audits/*
data/output/runs/*
data/output/exports/*
data/output/validation/*
data/output/visualizations/*.png
data/output/visualizations/*.pdf

# Root-level output files (from notebooks)
/*.csv
/*.json
!pyproject.toml
!package.json
!data/config.json

# API cache output
data/output/api/

# Testing
.coverage
coverage.xml
.pytest_cache/
.tox/
htmlcov/
*.cover
.hypothesis/

# Documentation
docs/_build/
site/

# Temporary Files
*.tmp
*.bak
*.swp
*~.nib
.cache/

# CI/CD
.github/workflows/*.log
