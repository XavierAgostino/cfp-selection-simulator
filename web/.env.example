# Selection Room web app — public read-only demo (Vercel)
# Copy to .env.local for local production builds that mirror the demo deploy.

# Bundled demo artifacts (created by pnpm seed-fixtures:demo at build time)
SELECTION_ROOM_DATA_DIR=.demo-data

# Public demo mode — hides Run Analysis, adjusts Scenario Lab copy
NEXT_PUBLIC_SELECTION_ROOM_DEMO_MODE=1

# Production URL for server-side fetches (set to your Vercel deployment URL)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Do NOT set on public demo:
# SELECTION_ROOM_ENABLE_RUN_JOBS=1
# CFBD_API_KEY=...
