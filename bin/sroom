#!/usr/bin/env bash
# Run sroom from the project venv without manual activation.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_BIN="$ROOT/.venv/bin/sroom"

if [[ -x "$VENV_BIN" ]]; then
  exec "$VENV_BIN" "$@"
fi

if command -v sroom >/dev/null 2>&1; then
  exec sroom "$@"
fi

echo "sroom not found." >&2
echo "Run: make setup" >&2
echo "Or:  $ROOT/.venv/bin/sroom <command>" >&2
exit 127
